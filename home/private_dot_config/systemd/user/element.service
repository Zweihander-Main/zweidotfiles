[Unit]
Description=Element Matrix Client
Requires=keepassxc.service
After=tray.service
ConditionFileIsExecutable=/usr/bin/element-desktop

[Service]
Type=exec
Restart=always
RestartSec=20s
ExecStart=element-desktop --hidden --disable-gpu-sandbox --password-store="gnome-libsecret"

[Install]
WantedBy=wm.target
